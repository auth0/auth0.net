<Project>
  <ItemGroup>
    <!-- Remove the InternalsVisibleTo without public key from the main csproj -->
    <AssemblyAttribute Remove="System.Runtime.CompilerServices.InternalsVisibleTo" />
    <!-- Add it back with the public key -->
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Auth0.ManagementApi.Test, </_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <!-- Remove all PolySharp entries (one from Directory.Build.props, one from the csproj)
       then re-add a single canonical reference to silence NU1504. -->
  <ItemGroup>
    <PackageReference Remove="PolySharp" />
    <PackageReference Include="PolySharp" Version="1.15.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Auth0.AuthenticationApi\Auth0.AuthenticationApi.csproj" />
  </ItemGroup>

  <ItemGroup Condition="!$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net9.0'))">
    <PackageReference Include="System.Net.ServerSentEvents" Version="9.0.14" />
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" Version="9.0.14" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFrameworks>net462;netstandard2.0</TargetFrameworks>
    <Version>8.2.0</Version>
    <AssemblyVersionNumber>8.2.0</AssemblyVersionNumber>
    <AssemblyVersion>$(AssemblyVersionNumber)</AssemblyVersion>
    <AssemblyFileVersion>$(AssemblyVersionNumber)</AssemblyFileVersion>  
    <InformationalVersion>$(Version)</InformationalVersion>
    <PackageVersion>$(Version)</PackageVersion>
    <FileVersion>$(Version)</FileVersion>
  </PropertyGroup>
</Project>
